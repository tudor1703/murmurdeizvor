# Admin email that receives contact form submissions
ADMIN_EMAIL=admin@murmurdeizvor.md

# SMTP credentials (any provider — Mailgun, SendGrid, Postmark, Gmail SMTP, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey-or-username
SMTP_PASSWORD=secret
SMTP_FROM=no-reply@murmurdeizvor.md

# Optional: TLS/SSL behavior. Defaults to STARTTLS on port 587 and SSL on port 465.
SMTP_USE_TLS=true

# Comma-separated list of allowed origins (frontend URLs)
ALLOWED_ORIGINS=http://localhost:3000,https://murmurdeizvor.md

# Optional: rate limit for /api/contact (per IP)
CONTACT_RATE_LIMIT=5/minute
